@model List<PawCare.Models.Pet>

<div class="container mt-4">
    <h2>❤️ Pets Available for Adoption</h2>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    <form method="get" class="mb-3">
        <div class="input-group">
            <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name or species..." />
            <button type="submit" class="btn btn-dark">🔍 Search</button>
        </div>
    </form>
    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No pets available for adoption.</div>
    }
    <div class="row">
        @foreach (var pet in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    @if (pet.ImageUrl != null)
                    {
                        <img src="@pet.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@pet.Name</h5>
                        <p>Species: @pet.Species</p>
                        <p>Breed: @pet.Breed</p>
                        <p>Age: @pet.Age years</p>
                        <p>@pet.Description</p>
                        <form asp-action="RequestAdoption" method="post">
                            <input type="hidden" name="petId" value="@pet.PetId" />
                            <div class="mb-2">
                                <textarea name="message" class="form-control" placeholder="Why do you want to adopt this pet?"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">❤️ Request Adoption</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>