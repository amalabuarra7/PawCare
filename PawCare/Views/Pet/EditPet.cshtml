@model PawCare.Models.Pet

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h3>✏️ Edit Pet</h3>
                </div>
                <div class="card-body">
                    <form asp-action="EditPet" method="post">
                        <input asp-for="PetId" type="hidden" />
                        <input asp-for="CreatedAt" type="hidden" />
                        <div class="mb-3">
                            <label>Pet Name</label>
                            <input asp-for="Name" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Species</label>
                            <input asp-for="Species" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Breed</label>
                            <input asp-for="Breed" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Age</label>
                            <input asp-for="Age" type="number" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Description</label>
                            <textarea asp-for="Description" class="form-control"></textarea>
                        </div>
                        <div class="mb-3">
                            <label>Image URL</label>
                            <input asp-for="ImageUrl" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label>Available for Adoption?</label>
                            <input asp-for="IsAvailableForAdoption" type="checkbox" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Save Changes</button>
                        <div class="mt-3 text-center">
                            <a asp-action="MyPets">Back to My Pets</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>