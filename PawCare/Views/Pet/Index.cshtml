@model List<PawCare.Models.Pet>

<div class="container mt-4">
    <h2>🐾 All Pets</h2>
    <form method="get" class="mb-3">
        <div class="input-group">
            <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name, species or breed..." />
            <button type="submit" class="btn btn-dark">🔍 Search</button>
        </div>
    </form>
    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No pets found.</div>
    }
    <div class="row">
        @foreach (var pet in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    @if (pet.ImageUrl != null)
                    {
                        <img src="@pet.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@pet.Name</h5>
                        <p>Species: @pet.Species</p>
                        <p>Breed: @pet.Breed</p>
                        <p>Age: @pet.Age years</p>
                        @if (pet.IsAvailableForAdoption)
                        {
                            <span class="badge bg-success">Available for Adoption</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Not Available</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>