<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h3>💉 Add Vaccination</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Add" method="post">
                        <input type="hidden" name="PetId" value="@ViewBag.PetId" />
                        <div class="mb-3">
                            <label>Vaccine Name</label>
                            <input name="VaccineName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label>Date Given</label>
                            <input name="DateGiven" type="date" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label>Next Due Date</label>
                            <input name="NextDueDate" type="date" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label>Notes</label>
                            <textarea name="Notes" class="form-control"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Add Vaccination</button>
                        <div class="mt-3 text-center">
                            <a asp-action="Index" asp-route-petId="@ViewBag.PetId">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>