@model PawCare.Models.User

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h3>👤 My Profile</h3>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    <table class="table">
                        <tr>
                            <td><strong>Full Name</strong></td>
                            <td>@Model.FullName</td>
                        </tr>
                        <tr>
                            <td><strong>Email</strong></td>
                            <td>@Model.Email</td>
                        </tr>
                        <tr>
                            <td><strong>Phone</strong></td>
                            <td>@Model.Phone</td>
                        </tr>
                        <tr>
                            <td><strong>Member Since</strong></td>
                            <td>@Model.CreatedAt.ToString("dd/MM/yyyy")</td>
                        </tr>
                    </table>
                    <a asp-action="EditProfile" class="btn btn-primary w-100 mb-2">✏️ Edit Profile</a>
                    <a asp-action="ChangePassword" class="btn btn-warning w-100 mb-2">🔒 Change Password</a>
                    <a asp-action="Logout" class="btn btn-danger w-100">🚪 Logout</a>
                </div>
            </div>
        </div>
    </div>
</div>